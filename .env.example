# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime.
# FOR VERCEL/GITHUB: You MUST manually add GEMINI_API_KEY to your 
# project's Environment Variables in the Vercel dashboard.
GEMINI_API_KEY="your_api_key_here"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this.
# FOR VERCEL: This will typically be your deployment URL.
APP_URL="https://your-app.vercel.app"
